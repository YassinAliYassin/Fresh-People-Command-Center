# Fresh People Command Center Environment Variables
# Copy this file to .env.local for local development or set in Vercel/Render dashboard

# === Required for Database ===
# Neon PostgreSQL connection string (get from https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# === Required for iCloud Calendar Integration ===
# Published iCloud .ics feed URL (get from Apple Calendar -> Calendar -> Preferences -> Sharing)
ICLOUD_CALENDAR_URL="https://p56-caldav.icloud.com/published/2/..."

# === Required for WhatsApp Notifications ===
# Meta WhatsApp Business API Access Token (from Meta Business Suite)
WHATSAPP_ACCESS_TOKEN="EAAvYl97Mh2Q..."
# WhatsApp Phone Number ID (from Meta Business Suite)
WHATSAPP_PHONE_NUMBER_ID="1190600000792870"
# WhatsApp Business Account ID (optional, for reference)
WABA_ID="2036327954427976"

# === Optional: Admin Authentication (for production) ===
# Uncomment and set a strong secret to enable auth on write endpoints
# ADMIN_SECRET="your-strong-secret-here"

# === Optional: App URL (auto-set by Vercel) ===
# APP_URL="https://fresh-people-command-center.vercel.app"
