# Google Calendar API (Service Account)
# 1. Go to https://console.cloud.google.com/
# 2. Create new project → Enable Google Calendar API
# 3. Create Service Account → Generate JSON key
# 4. Share your Google Calendar with the service account email
# 5. Encode the JSON key to base64: base64 service-account.json
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Vercel Deployment
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
